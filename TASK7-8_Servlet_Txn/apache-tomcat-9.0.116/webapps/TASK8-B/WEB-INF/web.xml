<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">

    <servlet>
        <servlet-name>sessionLogin</servlet-name>
        <servlet-class>SessionLoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>sessionLogin</servlet-name>
        <url-pattern>/login1</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>sessionRetrieve</servlet-name>
        <servlet-class>SessionRetrieveServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>sessionRetrieve</servlet-name>
        <url-pattern>/retrieve1</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>logout</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
</web-app>