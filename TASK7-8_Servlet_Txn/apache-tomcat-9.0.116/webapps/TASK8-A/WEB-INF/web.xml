<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="3.1">

    <servlet>
        <servlet-name>cookieLogin</servlet-name>
        <servlet-class>CookieLoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>cookieLogin</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>cookieRetrieve</servlet-name>
        <servlet-class>CookieRetrieveServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>cookieRetrieve</servlet-name>
        <url-pattern>/retrieve</url-pattern>
    </servlet-mapping>

</web-app>